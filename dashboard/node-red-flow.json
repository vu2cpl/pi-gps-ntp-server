    {
        "id": "uitemplate.gpsntp.card",
        "type": "ui_template",
        "z": "tab.gpsntp.card",
        "group": "uigroup.gpsntp.card",
        "name": "Chrony status card",
        "order": 1,
        "width": "10",
        "height": "10",
        "format": "<style>\n.gpsntp-card {\n  /* GitHub-dark palette — matches the rest of the VU2CPL shack dashboard */\n  --bg:     #0d1117;\n  --card:   #161b22;\n  --border: #30363d;\n  --text:   #c9d1d9;\n  --strong: #e6edf3;\n  --muted:  #8b949e;\n  --accent: #58a6ff;\n  --green:  #3fb950;\n  --amber:  #e3b341;\n  --red:    #f85149;\n\n  background: var(--card);\n  border: 1px solid var(--border);\n  border-radius: 8px;\n  width: 100%;\n  padding: 14px 16px;\n  font-family: -apple-system, \"SF Pro Text\", system-ui, sans-serif;\n  font-size: 13px;\n  color: var(--text);\n  -webkit-font-smoothing: antialiased;\n  box-sizing: border-box;\n}\n.gpsntp-card .ttl {\n  color: var(--strong);\n  font-weight: 600;\n  font-size: 14px;\n  margin: 0 0 10px;\n  letter-spacing: 0.02em;\n}\n.gpsntp-card .sect {\n  color: var(--muted);\n  text-align: center;\n  font-size: 11px;\n  font-weight: 500;\n  letter-spacing: 0.08em;\n  margin: 12px 0 8px;\n  user-select: none;\n}\n.gpsntp-card .sect:before,\n.gpsntp-card .sect:after {\n  content: \"\\2014\\2014\\2014\";\n  color: var(--border);\n  margin: 0 8px;\n  letter-spacing: -1px;\n}\n.gpsntp-card .row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 6px 0;\n  border-bottom: 1px solid var(--border);\n  gap: 10px;\n}\n.gpsntp-card .row:last-of-type { border-bottom: none; }\n.gpsntp-card .lab {\n  color: var(--text);\n  font-size: 12.5px;\n}\n.gpsntp-card .val {\n  color: var(--strong);\n  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\n  font-feature-settings: \"tnum\";\n  font-size: 12.5px;\n}\n.gpsntp-card .val.attn { color: var(--amber); }\n.gpsntp-card .chip {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  padding: 1px 10px;\n  border-radius: 12px;\n  font-size: 11px;\n  font-weight: 500;\n  border: 1px solid currentColor;\n  background: transparent;\n  letter-spacing: 0.02em;\n  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\n  font-feature-settings: \"tnum\";\n  white-space: nowrap;\n}\n.gpsntp-card .chip.good { color: var(--green); }\n.gpsntp-card .chip.info { color: var(--accent); }\n.gpsntp-card .chip.warn { color: var(--amber); }\n.gpsntp-card .chip.bad  { color: var(--red); }\n.gpsntp-card .led {\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  display: inline-block;\n  background: currentColor;\n  box-shadow: 0 0 4px currentColor;\n}\n.gpsntp-card .gps-val {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  color: var(--strong);\n  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\n  font-feature-settings: \"tnum\";\n  font-size: 12.5px;\n}\n.gpsntp-card .ftr {\n  margin-top: 12px;\n  padding-top: 9px;\n  border-top: 1px solid var(--border);\n  display: flex;\n  justify-content: space-between;\n  color: var(--muted);\n  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\n  font-feature-settings: \"tnum\";\n  font-size: 11.5px;\n  letter-spacing: 0.02em;\n}\n</style>\n\n<div class=\"gpsntp-card\">\n  <h3 class=\"ttl\">🛰 <span id=\"gpsntp-title\">GPS Time Server</span></h3>\n\n  <div class=\"sect\">SYNC STATUS</div>\n\n  <div class=\"row\">\n    <span class=\"lab\">Reference</span>\n    <span class=\"chip info\" id=\"gpsntp-ref\"><span class=\"led\"></span><span class=\"t\">—</span></span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">Stratum</span>\n    <span class=\"chip info\" id=\"gpsntp-stratum\"><span class=\"led\"></span><span class=\"t\">—</span></span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">System offset</span>\n    <span class=\"val\" id=\"gpsntp-sys\">—</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">RMS offset</span>\n    <span class=\"val\" id=\"gpsntp-rms\">—</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">Root dispersion</span>\n    <span class=\"val\" id=\"gpsntp-rd\">—</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">Skew</span>\n    <span class=\"val\" id=\"gpsntp-skew\">—</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">Leap</span>\n    <span class=\"val\" id=\"gpsntp-leap\">—</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">GPS</span>\n    <span class=\"gps-val\">\n      <span class=\"chip info\" id=\"gpsntp-fix\"><span class=\"led\"></span><span class=\"t\">—</span></span>\n      <span id=\"gpsntp-sats\">—</span>\n    </span>\n  </div>\n\n  <div class=\"ftr\">\n    <span id=\"gpsntp-utc\">—</span>\n    <span id=\"gpsntp-ago\">—</span>\n  </div>\n</div>\n\n<script>\n(function(scope) {\n  var DASH = '—';\n  var lastTs = 0;\n\n  function $(id)       { return document.getElementById(id); }\n  function setText(id, txt) { var el = $(id); if (el) el.textContent = txt; }\n  function setChip(id, txt, cls) {\n    var el = $(id); if (!el) return;\n    el.className = 'chip ' + cls;\n    var t = el.querySelector('.t');\n    if (t) t.textContent = txt;\n  }\n  function setVal(id, txt, attn) {\n    var el = $(id); if (!el) return;\n    el.textContent = txt;\n    el.className = 'val' + (attn ? ' attn' : '');\n  }\n\n  function fmtSigned(v) {\n    if (v === undefined || v === null) return DASH;\n    var sign = v >= 0 ? '+' : '-';\n    var a = Math.abs(v);\n    if (a < 1e-6) return sign + Math.round(a * 1e9) + ' ns';\n    if (a < 1e-3) return sign + (a * 1e6).toFixed(1) + ' µs';\n    if (a < 1)    return sign + (a * 1e3).toFixed(2) + ' ms';\n    return sign + a.toFixed(3) + ' s';\n  }\n  function fmtAbs(v) {\n    if (v === undefined || v === null) return DASH;\n    var a = Math.abs(v);\n    if (a < 1e-6) return Math.round(a * 1e9) + ' ns';\n    if (a < 1e-3) return (a * 1e6).toFixed(1) + ' µs';\n    if (a < 1)    return (a * 1e3).toFixed(2) + ' ms';\n    return a.toFixed(3) + ' s';\n  }\n  function pad2(n) { return (n < 10 ? '0' : '') + n; }\n  function utcTime(ts) {\n    if (!ts) return DASH;\n    var d = new Date(ts * 1000);\n    return pad2(d.getUTCHours()) + ':' + pad2(d.getUTCMinutes()) + ':' + pad2(d.getUTCSeconds()) + ' UTC';\n  }\n  function agoText(ts) {\n    if (!ts) return DASH;\n    var age = Math.max(0, Math.floor(Date.now() / 1000) - ts);\n    if (age < 60)   return age + ' s ago';\n    if (age < 3600) return Math.floor(age / 60) + ' m ago';\n    return Math.floor(age / 3600) + ' h ago';\n  }\n  function classifyRef(ref) {\n    if (ref === 'PPS' || ref === 'PPS2') return 'good';\n    if (ref === 'NMEA' || ref === 'NMEB') return 'warn';\n    return 'info';\n  }\n  function classifyStratum(s) {\n    if (s === 1) return 'good';\n    if (s >= 2 && s <= 15) return 'warn';\n    return 'bad';\n  }\n  function classifyFix(m) {\n    if (m === 3) return 'good';\n    if (m === 2) return 'warn';\n    return 'bad';\n  }\n\n  function render(p) {\n    var sys = p.system_time_offset_s || 0;\n    var rms = p.rms_offset_s         || 0;\n    var rd  = p.root_dispersion_s    || 0;\n    var sk  = p.skew_ppm             || 0;\n    lastTs  = p.ts || 0;\n\n    setChip('gpsntp-ref',     p.ref_name || DASH,                       classifyRef(p.ref_name));\n    setChip('gpsntp-stratum', (p.stratum === undefined ? DASH : p.stratum), classifyStratum(p.stratum));\n    setVal ('gpsntp-sys',     fmtSigned(sys),         Math.abs(sys) > 1e-3);\n    setVal ('gpsntp-rms',     fmtAbs(rms),            rms > 1e-3);\n    setVal ('gpsntp-rd',      fmtAbs(rd),             rd  > 5e-3);\n    setVal ('gpsntp-skew',    sk.toFixed(3) + ' ppm', Math.abs(sk) > 1);\n    setText('gpsntp-leap',    p.leap || DASH);\n\n    var fixText = p.fix_mode === 3 ? '3D'\n                : p.fix_mode === 2 ? '2D'\n                : 'no fix';\n    setChip('gpsntp-fix', fixText, classifyFix(p.fix_mode));\n    setText('gpsntp-sats',\n      (p.sat_used === undefined ? DASH : p.sat_used) + ' / ' +\n      (p.sat_seen === undefined ? DASH : p.sat_seen));\n\n    setText('gpsntp-utc', utcTime(lastTs));\n    setText('gpsntp-ago', agoText(lastTs));\n  }\n\n  scope.$watch('msg', function(msg) {\n    if (!msg || !msg.payload) return;\n    render(msg.payload);\n  });\n\n  if (!scope._gpsntpTicker) {\n    scope._gpsntpTicker = setInterval(function() {\n      if (lastTs) setText('gpsntp-ago', agoText(lastTs));\n    }, 5000);\n    scope.$on('$destroy', function() {\n      clearInterval(scope._gpsntpTicker);\n      scope._gpsntpTicker = null;\n    });\n  }\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": false,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 460,
        "y": 120,
        "wires": [
            []
        ]
    }
]