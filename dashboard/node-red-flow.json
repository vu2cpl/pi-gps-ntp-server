  {
    "id": "uitemplate.gpsntp.card",
    "type": "ui_template",
    "z": "tab.gpsntp.card",
    "group": "uigroup.gpsntp.card",
    "name": "Chrony status card",
    "order": 1,
    "width": "6",
    "height": "10",
    "format": "<style>\n.gpsntp-card {\n  background: #0e151e;\n  border: 1px solid #1c2530;\n  border-radius: 8px;\n  width: 100%;\n  padding: 14px 16px 14px;\n  font-family: -apple-system, \"SF Pro Text\", system-ui, sans-serif;\n  font-size: 13px;\n  color: #cdd6e0;\n  -webkit-font-smoothing: antialiased;\n  box-sizing: border-box;\n}\n.gpsntp-card .ttl {\n  color: #5cd0d6;\n  font-weight: 600;\n  font-size: 14px;\n  margin: 0 0 10px;\n  letter-spacing: 0.02em;\n}\n.gpsntp-card .sect {\n  color: #5cd0d6;\n  text-align: center;\n  font-size: 11px;\n  font-weight: 500;\n  letter-spacing: 0.08em;\n  margin: 12px 0 8px;\n  user-select: none;\n}\n.gpsntp-card .sect:before, .gpsntp-card .sect:after {\n  content: \"\\2014\\2014\\2014\";\n  color: #5cd0d6;\n  opacity: 0.7;\n  margin: 0 8px;\n  letter-spacing: -1px;\n}\n.gpsntp-card .row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 5px 0;\n  border-bottom: 1px solid #1a232c;\n  gap: 10px;\n}\n.gpsntp-card .row:last-of-type { border-bottom: none; }\n.gpsntp-card .lab {\n  color: #cdd6e0;\n  font-size: 12.5px;\n}\n.gpsntp-card .val {\n  color: #e6edf3;\n  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\n  font-feature-settings: \"tnum\";\n  font-size: 12.5px;\n}\n.gpsntp-card .val.attn { color: #e89a4a; }\n.gpsntp-card .chip {\n  display: inline-block;\n  padding: 1px 10px;\n  border-radius: 12px;\n  font-size: 11px;\n  font-weight: 500;\n  border: 1px solid currentColor;\n  background: transparent;\n  letter-spacing: 0.02em;\n  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\n  font-feature-settings: \"tnum\";\n  white-space: nowrap;\n}\n.gpsntp-card .chip.good { color: #5cd36e; }\n.gpsntp-card .chip.info { color: #5cd0d6; }\n.gpsntp-card .chip.warn { color: #e89a4a; }\n.gpsntp-card .chip.bad  { color: #e57373; }\n.gpsntp-card .gps-val {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  color: #e6edf3;\n}\n.gpsntp-card .ftr {\n  margin-top: 12px;\n  padding-top: 9px;\n  border-top: 1px solid #1a232c;\n  display: flex;\n  justify-content: space-between;\n  color: #7d8896;\n  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;\n  font-feature-settings: \"tnum\";\n  font-size: 11.5px;\n  letter-spacing: 0.02em;\n}\n</style>\n\n<div class=\"gpsntp-card\">\n  <h3 class=\"ttl\">\ud83d\udef0 {{data.title}}</h3>\n\n  <div class=\"sect\">SYNC STATUS</div>\n\n  <div class=\"row\">\n    <span class=\"lab\">Reference</span>\n    <span class=\"chip\" ng-class=\"data.ref_class\">{{data.ref_text}}</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">Stratum</span>\n    <span class=\"chip\" ng-class=\"data.stratum_class\">{{data.stratum}}</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">System offset</span>\n    <span class=\"val\" ng-class=\"{attn: data.sys_off_attn}\">{{data.sys_off}}</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">RMS offset</span>\n    <span class=\"val\" ng-class=\"{attn: data.rms_attn}\">{{data.rms}}</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">Root dispersion</span>\n    <span class=\"val\" ng-class=\"{attn: data.root_disp_attn}\">{{data.root_disp}}</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">Skew</span>\n    <span class=\"val\" ng-class=\"{attn: data.skew_attn}\">{{data.skew}}</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">Leap</span>\n    <span class=\"val\">{{data.leap}}</span>\n  </div>\n  <div class=\"row\">\n    <span class=\"lab\">GPS</span>\n    <span class=\"val gps-val\">\n      <span class=\"chip\" ng-class=\"data.fix_class\">{{data.fix_text}}</span>{{data.sat_used}}&nbsp;/&nbsp;{{data.sat_seen}}\n    </span>\n  </div>\n\n  <div class=\"ftr\">\n    <span>{{data.utc_time}}</span>\n    <span>{{data.ago}}</span>\n  </div>\n</div>\n\n<script>\n(function(scope) {\n  var DASH = '\u2014';\n\n  scope.data = scope.data || {\n    title: 'GPS Time Server',\n    ts: 0,\n    ref_text: DASH, ref_class: 'info',\n    stratum: DASH, stratum_class: 'info',\n    sys_off: DASH, sys_off_attn: false,\n    rms: DASH, rms_attn: false,\n    root_disp: DASH, root_disp_attn: false,\n    skew: DASH, skew_attn: false,\n    leap: DASH,\n    fix_text: DASH, fix_class: 'info',\n    sat_used: DASH, sat_seen: DASH,\n    utc_time: DASH, ago: DASH\n  };\n\n  function fmtSigned(v) {\n    if (v === undefined || v === null) return DASH;\n    var sign = v >= 0 ? '+' : '-';\n    var a = Math.abs(v);\n    if (a < 1e-6) return sign + Math.round(a * 1e9) + ' ns';\n    if (a < 1e-3) return sign + (a * 1e6).toFixed(1) + ' \u00b5s';\n    if (a < 1)    return sign + (a * 1e3).toFixed(2) + ' ms';\n    return sign + a.toFixed(3) + ' s';\n  }\n  function fmtAbs(v) {\n    if (v === undefined || v === null) return DASH;\n    var a = Math.abs(v);\n    if (a < 1e-6) return Math.round(a * 1e9) + ' ns';\n    if (a < 1e-3) return (a * 1e6).toFixed(1) + ' \u00b5s';\n    if (a < 1)    return (a * 1e3).toFixed(2) + ' ms';\n    return a.toFixed(3) + ' s';\n  }\n  function pad2(n) { return (n < 10 ? '0' : '') + n; }\n  function utcTime(ts) {\n    if (!ts) return DASH;\n    var d = new Date(ts * 1000);\n    return pad2(d.getUTCHours()) + ':' + pad2(d.getUTCMinutes()) + ':' + pad2(d.getUTCSeconds()) + ' UTC';\n  }\n  function agoText(ts) {\n    if (!ts) return DASH;\n    var age = Math.max(0, Math.floor(Date.now() / 1000) - ts);\n    if (age < 60)   return age + ' s ago';\n    if (age < 3600) return Math.floor(age / 60) + ' m ago';\n    return Math.floor(age / 3600) + ' h ago';\n  }\n  function classifyRef(ref) {\n    if (ref === 'PPS' || ref === 'PPS2') return 'good';\n    if (ref === 'NMEA' || ref === 'NMEB') return 'warn';\n    return 'info';\n  }\n  function classifyStratum(s) {\n    if (s === 1) return 'good';\n    if (s >= 2 && s <= 15) return 'warn';\n    return 'bad';\n  }\n  function classifyFix(m) {\n    if (m === 3) return 'good';\n    if (m === 2) return 'warn';\n    return 'bad';\n  }\n\n  function rebuild(p) {\n    var sys = p.system_time_offset_s || 0;\n    var rms = p.rms_offset_s         || 0;\n    var rd  = p.root_dispersion_s    || 0;\n    var sk  = p.skew_ppm             || 0;\n    return {\n      title:           'GPS Time Server',\n      ts:              p.ts || 0,\n      ref_text:        p.ref_name || DASH,\n      ref_class:       classifyRef(p.ref_name),\n      stratum:         (p.stratum === undefined ? DASH : p.stratum),\n      stratum_class:   classifyStratum(p.stratum),\n      sys_off:         fmtSigned(sys),\n      sys_off_attn:    Math.abs(sys) > 1e-3,\n      rms:             fmtAbs(rms),\n      rms_attn:        rms > 1e-3,\n      root_disp:       fmtAbs(rd),\n      root_disp_attn:  rd > 5e-3,\n      skew:            sk.toFixed(3) + ' ppm',\n      skew_attn:       Math.abs(sk) > 1,\n      leap:            p.leap || DASH,\n      fix_text:        p.fix_mode === 3 ? '3D'\n                     : p.fix_mode === 2 ? '2D'\n                     : 'no fix',\n      fix_class:       classifyFix(p.fix_mode),\n      sat_used:        (p.sat_used === undefined ? DASH : p.sat_used),\n      sat_seen:        (p.sat_seen === undefined ? DASH : p.sat_seen),\n      utc_time:        utcTime(p.ts || 0),\n      ago:             agoText(p.ts || 0)\n    };\n  }\n\n  scope.$watch('msg', function(msg) {\n    if (!msg || !msg.payload) return;\n    scope.data = rebuild(msg.payload);\n  });\n\n  if (!scope._gpsntpTicker) {\n    scope._gpsntpTicker = setInterval(function() {\n      if (scope.data && scope.data.ts) {\n        scope.data.ago = agoText(scope.data.ts);\n        try { scope.$apply(); } catch (e) {}\n      }\n    }, 5000);\n    scope.$on('$destroy', function() {\n      clearInterval(scope._gpsntpTicker);\n      scope._gpsntpTicker = null;\n    });\n  }\n})(scope);\n</script>\n",
    "storeOutMessages": true,
    "fwdInMessages": false,
    "resendOnRefresh": true,
    "templateScope": "local",
    "className": "",
    "x": 460,
    "y": 120,
    "wires": [
      []
    ]
  }
]
